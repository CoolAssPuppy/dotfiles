// Secrets.xcconfig.example
// Copy this file to Secrets.xcconfig and fill in your values.
// Secrets.xcconfig is gitignored. Never commit it.
//
// Build settings declared here are available in Info.plist via $(KEY_NAME)
// and in Swift code via Bundle.main.object(forInfoDictionaryKey:).
//
// This file exists even if you have no secrets yet, because the build
// scripts assume it's present. If you have nothing to put here, leave it
// empty (just whitespace).

// EXAMPLE_API_KEY = your-value-here
