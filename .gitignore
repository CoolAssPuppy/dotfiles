# Environment and secrets
.env
.env.*
*.env

# Private keys and certificates
*.pem
*.p8
*.p12
*.pfx
*.key
*.cer

# Credentials
*credentials*
*secrets*

# OS generated
.DS_Store
Thumbs.db

# Editor files
*.swp
*.swo
*~

# Third-party agent skill installer artifacts
# Tools like Stripe's and Supabase's installers detect every AI tool the
# user might run and dump per-tool symlinks into claude/skills/.<tool>/.
# Block those — the canonical content lives at claude/skills/<name>/.
# See claude/AGENT_SKILLS.md for the full list of committed partner skills.
claude/skills/.*/
claude/skills/skills/
